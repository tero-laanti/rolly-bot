[
  {
    "id": "example-basic-event",
    "rarity": "common",
    "title": "Example Basic Event",
    "prompt": "An example crate is sitting in the open. Check it?",
    "claimLabel": "Check crate",
    "claimPolicy": "first-click",
    "claimWindowSeconds": 75,
    "outcomes": [
      {
        "id": "example-success",
        "resolution": "resolve-success",
        "message": "Example success outcome: you find a useful item and get a small roll buff.",
        "effects": [
          {
            "type": "temporary-roll-multiplier",
            "multiplier": 2,
            "rolls": 2,
            "stackMode": "no-stack"
          }
        ]
      },
      {
        "id": "example-empty",
        "weight": 0.5,
        "resolution": "resolve-failure",
        "message": "Example failure outcome: the crate is empty and nothing else happens.",
        "effects": []
      }
    ],
    "activityTemplates": {
      "accepted": ["<@{userId}> checks the example crate.", "<@{userId}> opens the example event."],
      "alreadyReady": [
        "<@{userId}> is already checking the example crate.",
        "<@{userId}> is already in this example event."
      ]
    }
  },
  {
    "id": "example-keep-open-challenge",
    "rarity": "rare",
    "title": "Example Keep-Open Challenge",
    "prompt": "An example challenge needs two rolls: first 5+, then 3+. Try it?",
    "claimLabel": "Start challenge",
    "claimPolicy": "first-click",
    "claimWindowSeconds": 90,
    "retryPolicy": "once-per-user",
    "rollChallenge": {
      "id": "example-sequence-check",
      "mode": "sequence",
      "steps": [
        {
          "id": "step-one",
          "label": "Step 1: roll 5+ on your die",
          "source": { "type": "player-die" },
          "target": 5,
          "comparator": "gte"
        },
        {
          "id": "step-two",
          "label": "Step 2: roll 3+ on your die",
          "source": { "type": "player-die" },
          "target": 3,
          "comparator": "gte"
        }
      ],
      "failOnFirstMiss": true
    },
    "challengeOutcomeIds": {
      "success": ["example-challenge-success"],
      "failure": ["example-keep-open-failure"]
    },
    "outcomes": [
      {
        "id": "example-challenge-success",
        "resolution": "resolve-success",
        "message": "Example success outcome: you clear the challenge and get a stronger buff.",
        "effects": [
          {
            "type": "temporary-roll-multiplier",
            "multiplier": 4,
            "rolls": 3,
            "stackMode": "refresh"
          }
        ]
      },
      {
        "id": "example-keep-open-failure",
        "resolution": "keep-open-failure",
        "message": "Example keep-open failure: you miss the challenge, take a penalty, and the event stays open for someone else.",
        "effects": [
          {
            "type": "temporary-roll-penalty",
            "divisor": 2,
            "rolls": 1,
            "stackMode": "no-stack"
          }
        ]
      }
    ],
    "activityTemplates": {
      "accepted": [
        "<@{userId}> starts the example challenge.",
        "<@{userId}> takes the example attempt."
      ],
      "alreadyReady": [
        "<@{userId}> is already taking this example challenge.",
        "<@{userId}> is already in this example attempt."
      ]
    }
  }
]
