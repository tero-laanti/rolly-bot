# Required: Discord bot token from the Discord Developer Portal.
DISCORD_TOKEN=replace-me

# Required: Discord application client ID.
DISCORD_CLIENT_ID=replace-me

# Optional: development guild/server ID for fast slash-command updates.
# Leave empty to deploy commands globally instead.
DISCORD_GUILD_ID=

# Required: Discord user ID allowed to run owner-only commands such as
# /self-update and /dice-admin.
DISCORD_OWNER_ID=replace-me

# Optional but recommended for real gameplay data. This points to your private
# rolly-data checkout. If unset, the app tries ./rolly-data and then falls back
# to the public example data in ./example-data/rolly-data.
# ROLLY_DATA_DIR=./rolly-data

# Optional development-only escape hatch. Set this to true only if you
# intentionally want the app to start with the public example data.
# Leave unset in real deployments.
# ROLLY_ALLOW_EXAMPLE_DATA=false

# Optional but effectively required if random events are enabled and should post
# in Discord. This must be a text channel ID the bot can send messages to.
RANDOM_EVENTS_CHANNEL_ID=

# Optional random-event overrides.

# Enable or disable the random-event scheduler. Default: true
# RANDOM_EVENTS_ENABLED=true

# Target number of random events per day. Default: 10
# RANDOM_EVENTS_TARGET_PER_DAY=10

# Minimum gap between random-event opportunities in minutes. Default: 45
# RANDOM_EVENTS_MIN_GAP_MINUTES=45

# Maximum number of active random events at the same time. Default: 1
# RANDOM_EVENTS_MAX_ACTIVE=1

# Retry delay after a skipped or failed trigger in seconds. Default: 300
# RANDOM_EVENTS_RETRY_DELAY_SECONDS=300

# Scheduling jitter ratio used by the random-event scheduler. Default: 0.35
# RANDOM_EVENTS_JITTER_RATIO=0.35

# Quiet-hours start time in HH:MM 24-hour format. Default: 23:00
# RANDOM_EVENTS_QUIET_HOURS_START=23:00

# Quiet-hours end time in HH:MM 24-hour format. Default: 08:00
# RANDOM_EVENTS_QUIET_HOURS_END=08:00

# IANA timezone used for quiet hours. Default: Europe/Helsinki
# RANDOM_EVENTS_QUIET_HOURS_TIMEZONE=Europe/Helsinki
